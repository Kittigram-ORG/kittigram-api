    { "_id": "fld_auth", "_type": "request_group", "name": "Auth", "parentId": "wrk_1" },

    {
      "_id": "req_login",
      "_type": "request",
      "name": "Login",
      "parentId": "fld_auth",
      "method": "POST",
      "url": "{{ _.base_url }}/api/auth/login",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"{{ _.user_email }}\",\n  \"password\": \"Password1!\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "afterResponseScript": "const response = insomnia.response.json();\ninsomnia.environment.set('access_token', response.accessToken);\ninsomnia.environment.set('refresh_token', response.refreshToken);"
    },
    {
      "_id": "req_refresh",
      "_type": "request",
      "name": "Refresh Token",
      "parentId": "fld_auth",
      "method": "POST",
      "url": "{{ _.base_url }}/api/auth/refresh",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"refreshToken\": \"{{ _.refresh_token }}\"\n}"
      },
