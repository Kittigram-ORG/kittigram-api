    {
      "_id": "req_login",
      "_type": "request",
      "name": "Login",
      "parentId": "fld_auth",
      "method": "POST",
      "url": "{{ _.base_url }}/api/auth/login",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"tote@ciscoadiz.org\",\n  \"password\": \"password123\"\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "_id": "req_refresh",
      "_type": "request",
      "name": "Refresh Token",
      "parentId": "fld_auth",
      "method": "POST",
      "url": "{{ _.base_url }}/api/auth/refresh",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"refreshToken\": \"{{ _.refresh_token }}\"\n}"
      },
