# Copy this file to .env and fill in real values before running docker-compose.
# Never commit .env to version control.

# PostgreSQL
POSTGRES_USER=kittigram
POSTGRES_PASSWORD=change_me
POSTGRES_DB=kittigram

# MinIO
MINIO_ROOT_USER=kittigram
MINIO_ROOT_PASSWORD=change_me_min16chars
MINIO_DEFAULT_BUCKETS=kittigram

# gRPC shared secret (user-service ↔ auth-service)
GRPC_INTERNAL_SECRET=change_me

# Frontend URL (used in activation emails)
FRONTEND_URL=http://localhost:5173

# JWT keys (prod only — mount as files and set paths below)
# MP_JWT_VERIFY_PUBLICKEY_LOCATION=/run/secrets/publicKey.pem
